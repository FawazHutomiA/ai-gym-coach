# Contoh bentuk URL (jangan pakai contoh ini, pakai dari dashboard Anda):
# postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# =============================================================================
# Auth.js
# =============================================================================
# Wajib untuk login (JWT). Generate: openssl rand -base64 32
# Tanpa ini, setelah klik Sign in muncul "Server error / server configuration".
# Boleh juga pakai nama lama: NEXTAUTH_SECRET (fallback di kode).
AUTH_SECRET=

# Lokal:
AUTH_URL=http://localhost:3000
# Production (Vercel): ganti dengan URL deploy, mis. https://your-app.vercel.app
# AUTH_URL=https://your-app.vercel.app
#
# Masa token (JWT): access 24 jam, refresh 7 hari — konstanta di src/lib/auth/token-lifetimes.ts

# =============================================================================
# Setelah .env terisi — sinkron schema ke Neon (users, user_profiles, body_metric_entries,
# workout_sessions, workout_exercises, workout_sets):
#   bun run db:push
#
# Deploy Vercel: Project → Settings → Environment Variables
#   DATABASE_URL  = (string pooled Neon yang sama)
#   AUTH_SECRET   = secret acak
#   AUTH_URL      = https://<domain-produksi-anda>
#
# Opsional: Vercel → Integrations → Neon (menyambungkan project & mengisi env).

# =============================================================================
# Admin / super_admin
# =============================================================================
# Registrasi dari halaman utama selalu role `user`. Akun administrator tetap:
#   super_admin@gmail.com (password di-set lewat seed; produksi: pakai env di bawah).

# Password untuk akun seed super_admin (default dev: admin123):
# SUPER_ADMIN_SEED_PASSWORD=

# Bootstrap opsional jika belum ada satupun super_admin di DB:
# POST /api/admin/bootstrap — header x-admin-bootstrap-secret: <nilai di bawah>
# ADMIN_BOOTSTRAP_SECRET=

# Setelah db:push — sync permission + akun super_admin:
#   bun run db:seed
